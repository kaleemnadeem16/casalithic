Options -MultiViews
RewriteEngine On

# Always revalidate the HTML shell so it references the newest hashed assets
# immediately after each deployment.
<IfModule mod_headers.c>
  <Files "index.html">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Expires "0"
  </Files>
</IfModule>

# Contact diagnostics are filesystem-only and must never be served publicly.
RewriteRule ^api/logs(?:/|$) - [F,L,NC]

# Serve existing assets and the PHP contact endpoint normally.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send application routes such as /about and /collections/wardrobes to React.
RewriteRule ^ index.html [L]
